Structure de calendars/base.py :

from abc import ABC, abstractmethod
from datetime import date
from dataclasses import dataclass

@dataclass
class CalendarDate:
    year: int | str      # str pour les formats "Reiwa 6"
    month: int
    day: int
    calendar_name: str
    display_label: str   # Label affiché sur la carte
    era_name: str | None = None

class CalendarConverter(ABC):
    calendar_name: str

    @abstractmethod
    def from_gregorian(self, d: date) -> CalendarDate: ...

    @abstractmethod
    def to_gregorian(self, cd: CalendarDate) -> date: ...
Exemples d'implémentation (à comprendre avant de coder) :

# Persian : jdatetime fait le travail lourd
import jdatetime
from datetime import date

class PersianConverter(CalendarConverter):
    calendar_name = "persian"

    def from_gregorian(self, d: date) -> CalendarDate:
        jd = jdatetime.date.fromgregorian(date=d)
        return CalendarDate(
            year=jd.year, month=jd.month, day=jd.day,
            calendar_name="persian",
            display_label=f"{jd.day} {jd.strftime('%B')} {jd.year}"
        )

# Hebrew : pyluach
from pyluach.dates import HebrewDate
class HebrewConverter(CalendarConverter):
    def from_gregorian(self, d: date) -> CalendarDate:
        hd = HebrewDate.from_pydate(d)
        return CalendarDate(year=hd.year, month=hd.month, day=hd.day, ...)

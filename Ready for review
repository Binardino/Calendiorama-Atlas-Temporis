Algorithme de requête temporelle dans borders.py :

def get_borders_for_date(d: date) -> gpd.GeoDataFrame:
    if d >= CSHAPES_START:  # 1886-01-01
        # Chargement CShapes : filtre valid_from <= d <= valid_until
        gdf = load_cshapes()
        return gdf[(gdf['valid_from'] <= d) & (gdf['valid_until'] >= d)]
    else:
        # Snapshots aourednik : trouver le snapshot le plus proche avant d
        snapshot_year = max(y for y in SNAPSHOT_YEARS if y <= d.year)
        return load_snapshot(snapshot_year)
